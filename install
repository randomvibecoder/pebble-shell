#!/usr/bin/env bash
set -euo pipefail

PEBBLE_HOME="${PEBBLE_HOME:-$HOME/.pebble-shell}"
PEBBLE_REPO_URL="${PEBBLE_REPO_URL:-https://github.com/randomvibecoder/pebble-shell.git}"
PEBBLE_REF="${PEBBLE_REF:-main}"
PEBBLE_BIN_DIR="${PEBBLE_BIN_DIR:-$HOME/.local/bin}"

APP_DIR="$PEBBLE_HOME/app"
VENV_DIR="$PEBBLE_HOME/venv"
WORKSPACE_DIR="$PEBBLE_HOME/workspace"
ENV_FILE="$PEBBLE_HOME/.env"
TOKEN_FILE="$WORKSPACE_DIR/.pebble_shell/secrets/api_auth_token"

need() {
  if ! command -v "$1" >/dev/null 2>&1; then
    echo "Missing required command: $1" >&2
    exit 1
  fi
}

need git
need python3

mkdir -p "$PEBBLE_HOME" "$WORKSPACE_DIR" "$PEBBLE_BIN_DIR" "$(dirname "$TOKEN_FILE")"

if [ -d "$APP_DIR/.git" ]; then
  echo "Updating Pebble Shell in $APP_DIR"
  git -C "$APP_DIR" fetch --depth 1 origin "$PEBBLE_REF"
  git -C "$APP_DIR" checkout -q "$PEBBLE_REF" || git -C "$APP_DIR" checkout -q -B "$PEBBLE_REF" "origin/$PEBBLE_REF"
  git -C "$APP_DIR" reset --hard -q "origin/$PEBBLE_REF"
else
  echo "Installing Pebble Shell into $APP_DIR"
  rm -rf "$APP_DIR"
  git clone --depth 1 --branch "$PEBBLE_REF" "$PEBBLE_REPO_URL" "$APP_DIR"
fi

python3 -m venv "$VENV_DIR"
"$VENV_DIR/bin/python" -m pip install --upgrade pip
"$VENV_DIR/bin/python" -m pip install -e "$APP_DIR"

if [ ! -s "$TOKEN_FILE" ]; then
  "$VENV_DIR/bin/python" - <<'PY' >"$TOKEN_FILE"
import secrets
print(secrets.token_urlsafe(32))
PY
  chmod 600 "$TOKEN_FILE"
fi

API_AUTH_TOKEN="$(cat "$TOKEN_FILE")"

if [ ! -f "$ENV_FILE" ]; then
  cat >"$ENV_FILE" <<EOF
OPENAI_BASE_URL=https://nano-gpt.com/api/v1
OPENAI_API_KEY=replace-me
OPENAI_MODEL=xiaomi/mimo-v2.5:thinking
API_AUTH_TOKEN=$API_AUTH_TOKEN
API_AUTH_TOKEN_FILE=$TOKEN_FILE
EXA_API_KEY=
EXA_BASE_URL=https://api.exa.ai

DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_PUBLIC_KEY=
DISCORD_BOT_TOKEN=
DISCORD_ALLOWED_USER_ID=
INITIAL_DM_USER_ID=
INITIAL_DM_MESSAGE=Hi, I'm Pebble Shell. What's your name?

APP_HOST=0.0.0.0
APP_PORT=8080
AGENT_WORKSPACE=$WORKSPACE_DIR
MEMORY_DB_PATH=$WORKSPACE_DIR/.pebble_shell/memory.sqlite3
RUNTIME_CONFIG_DB_PATH=$WORKSPACE_DIR/.pebble_shell/runtime_config.sqlite3
EVENT_HOOKS_DB_PATH=$WORKSPACE_DIR/.pebble_shell/event_hooks.sqlite3
CRON_DB_PATH=$WORKSPACE_DIR/.pebble_shell/cron.sqlite3
SHELL_AUDIT_DB_PATH=$WORKSPACE_DIR/.pebble_shell/shell_audit.sqlite3
BACKGROUND_TASKS_DB_PATH=$WORKSPACE_DIR/.pebble_shell/background_tasks.sqlite3
MAX_BACKGROUND_TASKS=4
CRON_POLL_SECONDS=15
RECENT_MESSAGE_LIMIT=1000
RECENT_MESSAGE_TOKEN_BUDGET=0
HEARTBEAT_EVERY_SECONDS=7200
HEARTBEAT_ACK_MAX_CHARS=300
SHELL_TIMEOUT_SECONDS=20
MAX_AGENT_STEPS=200
MAX_DISCORD_IMAGE_BYTES=4000000
MAX_DISCORD_ATTACHMENT_BYTES=25000000
MAX_DISCORD_SEND_FILE_BYTES=25000000
DISCORD_ATTACHMENTS_DIR=sent_attachments
EOF
  chmod 600 "$ENV_FILE"
  echo "Created $ENV_FILE"
else
  echo "Keeping existing $ENV_FILE"
fi

PEBBLE_HOME_Q="$(printf '%q' "$PEBBLE_HOME")"
write_wrapper() {
  local name="$1"
  local target="$2"
  local target_q
  target_q="$(printf '%q' "$target")"
  cat >"$PEBBLE_BIN_DIR/$name" <<EOF
#!/usr/bin/env bash
export PEBBLE_HOME=$PEBBLE_HOME_Q
exec $target_q "\$@"
EOF
  chmod +x "$PEBBLE_BIN_DIR/$name"
}

write_wrapper pebble "$VENV_DIR/bin/pebble"
write_wrapper pebble-shell-discord-register "$VENV_DIR/bin/pebble-shell-discord-register"
write_wrapper pebble-shell-discord-dm "$VENV_DIR/bin/pebble-shell-discord-dm"

echo
echo "Pebble Shell installed."
echo "Config: $ENV_FILE"
echo "Workspace: $WORKSPACE_DIR"
echo "Command: $PEBBLE_BIN_DIR/pebble"
echo
echo "Next steps:"
echo "  1. Edit $ENV_FILE and set OPENAI_API_KEY plus any Discord/Exa settings."
echo "  2. Run: pebble serve"
echo
if [[ ":$PATH:" != *":$PEBBLE_BIN_DIR:"* ]]; then
  echo "Note: $PEBBLE_BIN_DIR is not in PATH. Add it or run:"
  echo "  $PEBBLE_BIN_DIR/pebble serve"
fi
